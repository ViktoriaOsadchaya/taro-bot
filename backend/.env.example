# PostgreSQL (совпадает с docker-compose.yml, порт хоста 5433)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/taro_bot
DB_ECHO=false

# Redis (сессии раскладов, FSM бота, порт хоста 6380)
REDIS_URL=redis://localhost:6380/0

# Telegram
BOT_TOKEN=
BOT_ENV=dev

# LLM через ProxyAPI
PROXYAPI_BASE_URL=
PROXYAPI_API_KEY=
PROXYAPI_MODEL=gpt-4o-mini

# Приложение
SECRET_KEY=change-me-in-production
INSTANCE_ID=default
