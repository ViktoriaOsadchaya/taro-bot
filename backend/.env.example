# PostgreSQL (совпадает с docker-compose.yml, порт хоста 5433)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/taro_bot
DB_ECHO=false

# Redis (сессии раскладов, FSM бота, порт хоста 6380)
REDIS_URL=redis://localhost:6380/0

# Telegram
BOT_TOKEN=
# Публичный HTTPS-адрес Mini App (ngrok фронтенда)
WEBAPP_URL=https://bullhorn-scarf-sublet.ngrok-free.dev
# Локальный адрес FastAPI для регистрации пользователей из бота
API_BASE_URL=http://127.0.0.1:8000
BOT_ENV=dev

# LLM через ProxyAPI
PROXYAPI_BASE_URL=
PROXYAPI_API_KEY=
PROXYAPI_MODEL=gpt-4o-mini

# Приложение
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
INSTANCE_ID=default
